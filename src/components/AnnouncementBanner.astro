---
interface Props {
  text: string;
  boldText?: string;
  href?: string;
}

const { text, boldText = "", href } = Astro.props as Props;
---

<div class="flex w-[calc(100%-2rem)] max-w-[980px] items-center rounded-lg border-4 border-black/20 bg-linear-to-l from-cta-start to-cta-end px-4 py-2 text-center text-black md:w-full sm:px-5 sm:py-3">
  <p class="m-0 w-full font-sans text-[17px] leading-[1.2] sm:text-[18px]">
    {text}
    {" "}
  {
    boldText ? (
      href ? (
        <a class="inline-flex items-center gap-2 font-bold text-black no-underline hover:underline" href={href}>
          <span>{boldText}</span>
          <img alt="" aria-hidden="true" class="size-4 shrink-0" src="/assets/home/button-arrow.svg" />
        </a>
      ) : (
        <span class="font-bold">{boldText}</span>
      )
    ) : null
  }
  </p>
</div>
