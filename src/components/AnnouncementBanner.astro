---
interface Props {
  text: string;
  boldText?: string;
  href?: string;
}

const { text, boldText = "", href } = Astro.props as Props;
---

<div class="inline-flex items-center gap-2 rounded-lg border-4 border-black/20 bg-gradient-to-l from-cta-start to-cta-end px-4 py-3 text-sm text-black sm:text-base">
  <span>{text}</span>
  {
    boldText ? (
      href ? (
        <a class="inline-flex items-center gap-2 font-bold text-black no-underline hover:underline" href={href}>
          <span>{boldText}</span>
          <img alt="" aria-hidden="true" class="size-4 shrink-0" src="/assets/home/button-arrow.svg" />
        </a>
      ) : (
        <span class="font-bold">{boldText}</span>
      )
    ) : null
  }
</div>
