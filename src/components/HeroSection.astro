---
import AnnouncementBanner from "./AnnouncementBanner.astro";
---

<section class="bg-brand-blue">
  <div class="mx-auto max-w-screen-2xl px-4 pb-8 sm:px-6 lg:px-8 lg:pb-12">
    <div class="flex flex-col items-center gap-10 pb-10 pt-4 text-center sm:gap-12 lg:gap-16 lg:pt-10">
      <!-- <AnnouncementBanner
        href="/about"
        text="We’re celebrating six years of cooperative tech at With the Ranks."
        boldText="See what’s next!"
      /> -->
      <div class="max-w-6xl">
        <h1 class="heading-hero mb-4 font-display font-normal text-white sm:mb-6">
          We build great tech<br />
          for good causes.
        </h1>
        <p class="body-hero mx-auto mb-2 max-w-3xl text-white">
          With the Ranks is a worker-owned technology cooperative supporting organizers building a better foundation for collective
          power.
        </p>
        <p class="body-hero mb-0 font-bold text-white">
          Here’s what we’ve been up to lately.
        </p>
      </div>

      <a
        aria-label="Scroll to the Mailer section"
        class="inline-flex h-16 w-12 items-center justify-center text-inherit no-underline transition duration-300 hover:translate-y-1 hover:scale-105 hover:opacity-90 hover:brightness-105 sm:h-[5.125rem] sm:w-16"
        href="/#mailer"
      >
        <img
          alt=""
          aria-hidden="true"
          class="h-full w-full object-contain"
          src="/assets/home/hero-marker.svg"
        />
      </a>
    </div>
  </div>
</section>
