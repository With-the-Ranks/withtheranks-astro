---
import Button from "./Button.astro";
---

<section class="bg-brand-blue">
  <div class="mx-auto max-w-home-shell px-4 pb-16 sm:px-6 lg:px-8 lg:pb-24">
    <div class="flex flex-col items-center gap-6 pb-12 pt-2 text-center sm:gap-8 lg:gap-16 lg:pt-8">
      <Button
        class="max-w-hero-pill !gap-4 !rounded-lg px-4 py-4 text-home-cta-sm leading-tight sm:px-6 sm:text-home-cta-sm-lg"
        href="/#mailer"
        icon="/assets/home/launch-pill-arrow.svg"
        iconClass="h-4 w-4 shrink-0"
        soft
        variant="cta"
      >
        <span class="font-normal">
          We just launched <strong>Mailer</strong>, the easiest way to send organizing emails -
          <strong> and it’s open source, too!</strong>
        </span>
      </Button>

      <div class="max-w-hero-copy">
        <h1 class="mb-4 font-display text-home-hero font-normal leading-none text-white">
          We build great tech<br />
          for good causes.
        </h1>
        <p class="mx-auto mb-2 max-w-hero-body text-home-hero-body text-white">
          With the Ranks is a worker-owned technology cooperative building software for the organizers who are saving the world.
        </p>
        <p class="mb-0 text-home-hero-body font-bold text-white">
          Here’s what we’ve been up to lately.
        </p>
      </div>

      <a
        aria-label="Scroll to the Mailer section"
        class="inline-flex h-16 w-12 items-center justify-center text-inherit no-underline transition duration-300 hover:translate-y-1 hover:scale-105 hover:opacity-90 hover:brightness-105 sm:h-scroll-cue sm:w-16"
        href="/#mailer"
      >
        <img
          alt=""
          aria-hidden="true"
          class="h-full w-full object-contain"
          src="/assets/home/hero-marker.svg"
        />
      </a>
    </div>
  </div>
</section>
