---
import InquiryForm from "../react/InquiryForm.tsx";
---

<section
  class="relative overflow-x-hidden px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-32"
  id="signup"
>
  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-[#00033d] to-[#232cd6]"></div>
  <div class="relative mx-auto flex max-w-screen-lg flex-col items-center gap-8 text-center text-white">
    <h2 class="font-display text-6xl leading-tight sm:text-8xl lg:text-[112px] lg:leading-[1.05]">
      Ready to start texting?
    </h2>
    <p class="max-w-xl font-sans text-lg sm:text-[22px]">Use the form below to get started and our team will follow up.</p>
  </div>
  <div class="relative mx-auto mt-10 max-w-[800px] w-full">
    <InquiryForm
      client:load
      initialInquiryType="spoke-services"
      removeTopMargin
      showAllOptions={false}
    />
  </div>
</section>
