---
import { CALENDLY_TEAM_MEETING } from "../../constants/spoke";
import Button from "../Button.astro";
---

<section
  class="border-b-4 border-[#1c1c1c]/20 bg-[#212bdd] px-4 pb-10 pt-2 sm:px-6 lg:px-8"
  id="overview"
>
  <div class="mx-auto flex max-w-screen-2xl flex-col gap-10 lg:flex-row lg:items-center lg:justify-between lg:gap-4">
    <div class="flex max-w-xl flex-col gap-8 lg:py-8 lg:pl-4 xl:pl-8">
      <div class="flex flex-col gap-4 text-white">
        <h1 class="font-display text-4xl leading-none sm:text-5xl lg:text-[48px]">
          Spoke makes it easy for organizers to send and reply to millions of text messages.
        </h1>
        <p class="font-sans text-lg leading-normal sm:text-xl">
          Start sending effective organizing messages with the proven open-source peer-to-peer texting platform, now
          backed by With the Ranks.
        </p>
      </div>
      <div class="flex flex-wrap gap-6">
        <Button
          class="label-button !inline-flex !gap-1 px-8 py-4 !text-black"
          href="#signup"
          icon="/assets/home/contact-icon.svg"
          iconClass="size-9 shrink-0"
          soft
          variant="cta"
        >
          <span>Sign Up</span>
        </Button>
        <a
          class="inline-flex items-center justify-center gap-2 rounded-lg border-4 border-[#1c1c1c]/20 px-6 py-4 font-sans text-base font-bold text-white no-underline transition duration-300 hover:-translate-y-px hover:bg-white/10 hover:brightness-110 focus-visible:-translate-y-px focus-visible:bg-white/10 focus-visible:brightness-110"
          href={CALENDLY_TEAM_MEETING}
          rel="noopener noreferrer"
          target="_blank"
        >
          <img
            alt=""
            aria-hidden="true"
            class="size-6 shrink-0 brightness-0 invert"
            src="/assets/home/contact-schedule.svg"
            width="24"
            height="24"
          />
          Schedule a Demo
        </a>
      </div>
    </div>
    <div class="relative flex min-w-0 flex-1 justify-center lg:justify-end lg:p-8 xl:p-16">
      <div class="relative inline-grid max-w-full place-items-start leading-none">
        <div class="relative col-start-1 row-start-1 w-full max-w-[788px] rounded-2xl border-2 border-[#cfcfcf]">
          <img
            alt=""
            class="block h-auto w-full rounded-2xl"
            height="429"
            src="/assets/spoke/hero-dashboard.png"
            width="788"
          />
        </div>
        <div
          aria-hidden="true"
          class="spoke-hero-chat-card relative z-10 col-start-1 row-start-1 mt-16 ml-auto flex aspect-9/16 w-[min(168px,38vw)] max-w-[200px] shrink-0 flex-col overflow-hidden rounded-[2.25rem] border-[3px] border-[#d4d4d9] bg-[#e8e8ed] p-[5px] shadow-[0_8px_22px_rgba(0,0,0,0.18)] ring-1 ring-black/10 sm:mt-20 sm:mr-4 lg:mt-20 lg:mr-8"
        >
          <div
            class="flex min-h-0 min-w-0 flex-1 flex-col overflow-hidden rounded-[1.85rem] bg-[#f2f2f7]"
          >
            <div class="flex shrink-0 justify-center pt-2.5 pb-1">
              <div class="h-[7px] w-[32%] max-w-[68px] rounded-full bg-[#1c1c1c]" />
            </div>
            <div
              class="spoke-hero-chat-screen flex min-h-0 min-w-0 flex-1 flex-col justify-end gap-2 overflow-hidden px-2 pb-2.5 pt-0.5"
            >
              <div
                class="spoke-hero-chat-bubble spoke-hero-chat-bubble--in min-w-0 rounded-[14px] rounded-bl-md bg-[#e9eaff] px-2 py-1.5"
              >
                <p
                  class="font-sans text-[9px] leading-snug text-[#1c1c1c] [overflow-wrap:anywhere] line-clamp-5"
                >
                  Hi Sarah — it’s Chris with Friends of Bernie Sanders. Can you make it to the canvass this Saturday?
                </p>
              </div>
              <div class="spoke-hero-chat-bubble spoke-hero-chat-bubble--out flex min-w-0 w-full justify-end">
                <div
                  class="max-w-full rounded-[14px] rounded-br-md bg-[#1f2aff] px-2 py-1.5 shadow-[0_2px_8px_rgba(31,42,255,0.35)]"
                >
                  <p class="font-sans text-[11px] leading-snug text-white">Yes! Where at?</p>
                </div>
              </div>
              <div class="spoke-hero-chat-bubble spoke-hero-chat-bubble--typing flex w-full min-w-0 justify-start">
                <div class="flex items-center rounded-[14px] rounded-bl-md bg-[#e9eaff] px-2 py-1.5">
                  <span class="spoke-hero-chat-typing inline-flex">
                    <img alt="" class="h-1 w-5" height="4" src="/assets/spoke/typing-dots.svg" width="20" />
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .spoke-hero-chat-card {
    --spoke-hero-chat-ease: cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: 90% 100%;
    animation: spoke-hero-chat-card-in 0.9s var(--spoke-hero-chat-ease) both;
  }
  @keyframes spoke-hero-chat-card-in {
    from {
      opacity: 0;
      filter: blur(4px);
      transform: translate3d(0, 18px, 0) scale(0.94) rotate(-1deg);
    }
    to {
      opacity: 1;
      filter: none;
      transform: none;
    }
  }
  @keyframes spoke-hero-chat-bubble-pop {
    from {
      opacity: 0;
      transform: translate3d(var(--x), var(--y), 0) scale(var(--s, 0.96));
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes spoke-hero-chat-typing-pulse {
    0%,
    100% {
      opacity: 0.75;
      transform: none;
    }
    50% {
      opacity: 1;
      transform: translate3d(0, -2px, 0);
    }
  }
  .spoke-hero-chat-bubble--in {
    --x: -10px;
    --y: 12px;
    animation: spoke-hero-chat-bubble-pop 0.65s var(--spoke-hero-chat-ease) 0.4s both;
  }
  .spoke-hero-chat-bubble--out {
    --x: 12px;
    --y: 12px;
    animation: spoke-hero-chat-bubble-pop 0.65s var(--spoke-hero-chat-ease) 0.85s both;
  }
  .spoke-hero-chat-bubble--typing {
    --x: -6px;
    --y: 8px;
    --s: 1;
    animation: spoke-hero-chat-bubble-pop 0.55s var(--spoke-hero-chat-ease) 1.25s both;
  }
  .spoke-hero-chat-typing {
    animation: spoke-hero-chat-typing-pulse 1.1s ease-in-out 1.55s infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .spoke-hero-chat-card,
    .spoke-hero-chat-bubble--in,
    .spoke-hero-chat-bubble--out,
    .spoke-hero-chat-bubble--typing,
    .spoke-hero-chat-typing {
      animation: none !important;
      filter: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
