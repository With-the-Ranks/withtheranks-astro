---
const cards = [
  {
    title: "Improved User Experience",
    body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.",
    iconClass: "iconoir-task-list",
  },
  {
    title: "Upgraded Security and Stability",
    body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.",
    iconClass: "iconoir-group",
  },
  {
    title: "Supported by With the Ranks",
    body: "Our team has been building and using Spoke since 2016, and when you have a problem you’ll be supported directly by our internal team of real humans building stuff.",
    iconClass: "iconoir-forward-message",
    href: "/about#who-we-are",
    linkLabel: "Meet the team",
  },
] as const;
---

<section class="border-b-4 border-t-4 border-black/20 bg-[#1f2aff] px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-32" id="backed">
  <div class="mx-auto flex max-w-screen-2xl flex-col items-center gap-16">
    <div class="max-w-[960px] text-white">
      <h2 class="font-display text-5xl leading-none sm:text-7xl lg:text-[90px]">Backed by With the Ranks.</h2>
      <div class="mt-4 max-w-[915px] space-y-4 font-sans text-xl leading-normal sm:text-2xl">
        <p>
          Spoke has been powering organizers for over a decade, including the Bernie Sanders 2020 presidential campaign
          that sent over 260 million messages.
        </p>
        <p>
          We’ve worked hard to bring modern improvements to the platform, including major user experience upgrades and
          enterprise level stability, and are committed to keeping it <span class="font-bold underline">open source</span> and accessible to all.
        </p>
      </div>
    </div>
    <div class="grid w-full grid-cols-1 gap-8 lg:grid-cols-3 lg:gap-16">
      {
        cards.map((card) => (
          <div class="rounded border-4 border-[#1c1c1c] bg-white p-8">
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-2">
                <i class:list={[card.iconClass, "shrink-0 text-2xl leading-none text-[#1c1c1c]"]} aria-hidden="true" />
                <h3 class="font-display text-3xl leading-none text-[#1c1c1c] sm:text-4xl">{card.title}</h3>
              </div>
              <p class="font-sans text-base leading-normal text-[#1c1c1c]">{card.body}</p>
              {"href" in card && card.href ? (
                <a class="inline-flex items-center gap-2 font-sans text-base font-bold text-[#1c1c1c] no-underline" href={card.href}>
                  {card.linkLabel}
                  <i
                    class="iconoir-arrow-up-right-square-solid shrink-0 text-2xl leading-none text-cta-end"
                    aria-hidden="true"
                  />
                </a>
              ) : null}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
