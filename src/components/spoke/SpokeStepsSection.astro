---
const steps = [
  {
    title: "1. Create a campaign",
    imgSrc: "/assets/spoke/create-campaign.png",
  },
  { title: "2. Upload your list", imgSrc: "/assets/spoke/upload-list.png" },
  {
    title: "3. Send text messages",
    imgSrc: "/assets/spoke/send-texts.png",
  },
  { title: "4. Reply and record", imgSrc: "/assets/spoke/send-replies.png" },
];
---

<section class="bg-brand-blue px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-32">
  <div class="mx-auto flex max-w-[960px] flex-col items-center gap-16">
    <div class="flex flex-col items-center gap-4 text-center text-white">
      <h2 class="font-display text-5xl leading-none sm:text-7xl lg:text-[90px]">One-on-one conversations at scale.</h2>
      <p class="max-w-[862px] font-sans text-xl leading-normal sm:text-2xl">
        Have meaningful conversations with supporters, record responses, and easily sync data back to your CRM, all in
        one affordable package.
      </p>
    </div>
    <div class="grid w-full grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      {
        steps.map(({ title, imgSrc }) => (
          <div class="flex flex-col items-center gap-8">
            <h3 class="w-full text-center font-display text-3xl leading-none text-white sm:text-4xl">
              {title}
            </h3>
            <div class="relative aspect-[4/3] w-full overflow-hidden rounded border-2 border-white/20">
              <img
                alt=""
                class="absolute inset-0 size-full object-cover"
                src={imgSrc}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
