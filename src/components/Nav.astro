---
import Button from "./Button.astro";

interface Props {
  theme?: string;
  surfaceClass?: string;
}

const { theme = "dark", surfaceClass } = Astro.props;

const navLinks = [
  { href: "/our-work", label: "Our Work", icon: "/assets/home/nav-our-work.svg" },
  { href: "/spoke", label: "Spoke", iconoir: "iconoir-smartphone-device" },
  { href: "/about", label: "Our Co-op", icon: "/assets/home/nav-company.svg" },
  { href: "https://spoke.withtheranks.com/", label: "Support", icon: "/assets/home/nav-support.svg" },
] as const;
const isLight = theme === "light";
const wrapperBg =
  surfaceClass ?? (isLight ? "bg-white" : "bg-brand-blue");
const lightFilter =
  "brightness(0) saturate(100%) invert(9%) sepia(28%) saturate(1940%) hue-rotate(210deg) brightness(94%) contrast(96%)";
---

<div class={wrapperBg} id="site-nav">
  <header class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <div class="flex min-w-0 items-center justify-between gap-4 lg:grid lg:grid-cols-[auto_1fr_auto] lg:items-center lg:gap-10">
      <div class="flex items-center justify-between gap-4">
        <a class="block shrink-0 text-inherit no-underline" href="/">
          <img alt="With the Ranks" class="h-auto w-32 sm:w-40 lg:w-48 xl:w-56" src="/assets/home/logo.svg" style={isLight ? `filter: ${lightFilter};` : undefined} />
        </a>
      </div>
      <button aria-label="Open menu" class={`inline-flex size-12 appearance-none items-center justify-center rounded-lg border-0 bg-transparent p-0 shadow-none transition-colors lg:hidden ${isLight ? "text-brand-navy hover:bg-brand-blue/10" : "text-white hover:bg-white/10"}`} id="mobile-menu-btn" type="button">
        <svg class="size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 6h16M4 12h16m-7 6h7" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </button>

      <nav aria-label="Primary" class="hidden lg:flex lg:items-center lg:justify-center lg:gap-6">
        {
          navLinks.map((link) => (
            <a class={`inline-flex shrink-0 items-center gap-2 rounded-lg px-5 py-2 text-base no-underline transition-colors ${isLight ? "!text-brand-navy hover:bg-brand-blue/10 hover:!text-brand-navy" : "!text-white hover:bg-white/10 hover:!text-white"}`} href={link.href}>
              {"iconoir" in link ? (
                <i
                  class:list={[
                    link.iconoir,
                    "not-italic shrink-0 text-2xl leading-none",
                    isLight ? "text-brand-navy" : "text-white",
                  ]}
                  aria-hidden="true"
                />
              ) : (
                <img alt="" aria-hidden="true" class="size-6 shrink-0" src={link.icon} style={isLight ? `filter: ${lightFilter};` : undefined} />
              )}
              <span class="whitespace-nowrap">{link.label}</span>
            </a>
          ))
        }
      </nav>

      <div class="hidden lg:flex lg:justify-end">
        <Button class="label-button !inline-flex !gap-1 px-8 py-4 !text-black" href="/contact" icon="/assets/home/contact-icon.svg" iconClass="size-9 shrink-0" soft variant="cta"><span>Contact us</span></Button>
      </div>
    </div>
  </header>

  <div class={`fixed inset-0 z-50 hidden opacity-0 transition-opacity duration-300 lg:hidden ${isLight ? "bg-brand-cream" : "bg-brand-blue"}`} id="mobile-menu">
    <div class="flex h-full flex-col">
      <div class="flex items-start justify-end px-4 py-6 sm:px-6 sm:py-8">
        <button aria-label="Close menu" class={`inline-flex size-12 appearance-none items-center justify-center rounded-lg border-0 bg-transparent p-0 shadow-none transition-colors ${isLight ? "text-brand-navy hover:bg-brand-blue/10" : "text-white hover:bg-white/10"}`} id="mobile-menu-close" type="button">
          <svg class="size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </button>
      </div>
      <nav aria-label="Mobile" class="flex flex-1 flex-col items-center justify-center gap-4 px-6 pb-8 text-center">
        {
          navLinks.map((link) => (
            <a class={`text-2xl font-bold no-underline transition-colors ${isLight ? "!text-brand-navy hover:text-brand-blue" : "!text-white hover:text-white/80"}`} href={link.href}>
              {link.label}
            </a>
          ))
        }
        <Button class="label-button mt-4 !gap-1 px-8 py-4 !text-black" href="/contact" icon="/assets/home/contact-icon.svg" iconClass="size-9 shrink-0" soft variant="cta"><span>Contact us</span></Button>
      </nav>
    </div>
  </div>
</div>

<script>
  const setupMobileMenu = () => {
    const menuBtn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("mobile-menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    if (!menuBtn || !closeBtn || !mobileMenu || menuBtn.dataset.menuBound === "true") return;

    const closeMobileNav = () => {
      mobileMenu.classList.add("hidden", "opacity-0");
      mobileMenu.classList.remove("opacity-100");
      document.body.classList.remove("overflow-hidden");
    };

    const openMobileNav = () => {
      mobileMenu.classList.remove("hidden", "opacity-0");
      mobileMenu.classList.add("opacity-100");
      document.body.classList.add("overflow-hidden");
    };

    const toggleMobileNav = () => {
      if (mobileMenu.classList.contains("hidden")) {
        openMobileNav();
      } else {
        closeMobileNav();
      }
    };

    menuBtn.dataset.menuBound = "true";
    closeBtn.dataset.menuBound = "true";
    menuBtn.addEventListener("click", toggleMobileNav);
    closeBtn.addEventListener("click", closeMobileNav);
    mobileMenu.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMobileNav));
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024) closeMobileNav();
    });
  };

  document.addEventListener("DOMContentLoaded", setupMobileMenu);
  document.addEventListener("astro:page-load", setupMobileMenu);
</script>
