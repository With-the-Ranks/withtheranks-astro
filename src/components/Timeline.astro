---
interface TimelineEntry {
	year: string;
	title?: string;
	description?: string;
	link?: { text: string; href: string };
	items?: {
		title?: string;
		description?: string;
		highlight?: boolean;
		content?: string;
		link?: { text: string; href: string };
	}[];
}

const entries = Astro.props.entries as TimelineEntry[];
---

<style>
	.fade-in {
		opacity: 0;
		transform: translateY(30px);
		transition:
			opacity 2s ease-out,
			transform 2s ease-out;
	}

	.fade-in.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.grow-line {
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.8s ease-out;
	}

	.grow-line.visible {
		transform: scaleY(1);
	}

	.slide-in-left {
		opacity: 0;
		transform: translateX(-20px);
		transition:
			opacity 2s ease-out,
			transform 2s ease-out;
	}

	.slide-in-left.visible {
		opacity: 1;
		transform: translateX(0);
	}

	.pop-in {
		opacity: 0;
		transform: scale(0.8);
		transition:
			opacity 2s ease-out,
			transform 2s ease-out;
	}

	.pop-in.visible {
		opacity: 1;
		transform: scale(1);
	}
</style>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const elements = document.querySelectorAll(
			".fade-in, .grow-line, .slide-in-left, .pop-in"
		);

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("visible");
					}
				});
			},
			{ threshold: 0.2 }
		);

		elements.forEach((el) => observer.observe(el));
	});
</script>

<div
	class='timeline-container mx-auto box-border min-w-0 w-full max-w-4xl px-0 py-0 sm:px-12 md:py-12'
>
	{
		entries.map((entry: TimelineEntry) => (
			<div
				class='timeline-entry relative flex min-w-0 gap-3 pb-16 fade-in sm:gap-4 md:gap-8'
				data-key={entry.year}>
				<div class='timeline-year-container relative flex w-10 shrink-0 flex-col items-center sm:w-11'>
					<div class='absolute top-0 bottom-0 w-0.5 bg-brand-navy grow-line' />

					<div class='year-badge relative z-10 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-cta-end font-sans text-base font-bold text-brand-navy fade-in lg:h-10 lg:w-10 lg:text-2xl'>
						{entry.year}
					</div>

						<div class='absolute top-full h-16 w-0.5 bg-brand-navy grow-line' />
				</div>

				<div class='timeline-content min-w-0 flex-1 space-y-12'>
					{entry.items &&
						entry.items.map((item, idx) => (
							<div
								class:list={[
									"fade-in box-border max-w-full min-w-0 rounded-sm",
									item.highlight
										? "border-4 border-[#0b124c] bg-white p-4 text-[#0b124c] sm:p-8"
										: "bg-white text-foreground sm:px-8",
								]}
								data-key={idx}
							>
								<div
									class:list={[
										"flex flex-col items-start gap-4 md:flex-row",
										!item.highlight && "px-4",
									]}
								>
									{item.highlight && (
										<div class='flex shrink-0 items-center pop-in'>
											<img
												src='/assets/bulb.svg'
												alt=''
												class='w-8 h-8 sm:w-10 sm:h-10'
											/>
										</div>
									)}

									<div class='min-w-0 flex-1'>
										{item.title && (
											<h3
												class:list={[
													"mb-4 font-display text-base font-normal sm:text-3xl",
													item.highlight
														? "text-[#0b124c]"
														: "text-brand-navy",
												]}
											>
												{item.title}
											</h3>
										)}

										{item.description && (
											<p
												class:list={[
													"mb-0 font-sans text-base leading-relaxed sm:text-lg",
													item.highlight ? "text-[#0b124c]" : "text-brand-navy",
												]}
											>
												{item.description}
											</p>
										)}

										{item.content && (
											<p
												class:list={[
													"font-sans text-lg leading-relaxed",
													item.highlight ? "text-[#0b124c]" : "text-brand-navy",
												]}
											>
												{item.content}
											</p>
										)}

										{item.link && (
											<a
												href={item.link.href}
												target="_blank"
												rel="noopener noreferrer"
												class:list={[
													"link-inline-external-icon group max-w-full min-w-0 break-words font-sans font-normal not-italic no-underline transition-colors",
													item.highlight
														? "text-base text-[#0b124c] hover:!text-[#0b124c]"
														: "text-sm text-brand-navy hover:!text-brand-navy sm:text-base",
												]}
											>
												<span class="min-w-0 break-words group-hover:underline">{item.link.text}</span><i
													class="iconoir-arrow-up-right-square-solid text-2xl leading-none text-cta-end not-italic"
													aria-hidden="true"
												></i></a>
										)}
									</div>
								</div>
							</div>
						))}
				</div>
			</div>
		))
	}
</div>
