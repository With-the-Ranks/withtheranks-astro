---
export interface Props {
  id?: string;
  text?: string;
  link?: string;
  href?: string;
  class?: string;
  icon?: string;
  iconClass?: string;
  soft?: boolean;
  variant?: "default" | "cta";
}

const {
  text,
  link,
  href = link,
  id,
  class: customClass = "",
  icon,
  iconClass = "size-6 shrink-0",
  soft = false,
  variant = "default",
  ...props
} = Astro.props;

const isCta = variant === "cta";
const ctaIcon = icon ?? "/assets/home/button-arrow.svg";
const hasSlot = Astro.slots.has("default");
---

{
  isCta ? (
    <a
      class:list={[
        "group/cta relative inline-flex items-center justify-center overflow-hidden bg-gradient-to-l from-cta-start to-cta-end font-bold leading-none !text-black no-underline transition duration-300 hover:-translate-y-px hover:brightness-105 hover:saturate-105 hover:!text-black focus-visible:-translate-y-px focus-visible:brightness-105 focus-visible:saturate-105 focus-visible:!text-black",
        soft
          ? "gap-1 rounded-xl outline outline-4 outline-black/20"
          : "gap-4 rounded-lg outline outline-2 outline-offset-inward outline-black",
        customClass,
      ]}
      href={href}
      id={id}
      {...props}
    >
      <span
        aria-hidden="true"
        class="absolute inset-0 -translate-x-full -skew-x-12 bg-gradient-to-r from-transparent via-white/35 to-transparent transition-transform duration-500 group-hover/cta:translate-x-full group-focus-visible/cta:translate-x-full"
      ></span>
      <span class="relative z-10 contents">
        {hasSlot ? <slot /> : text}
        <img alt="" aria-hidden="true" class={iconClass} src={ctaIcon} />
      </span>
    </a>
  ) : (
    <a
      class:list={[
        "w-auto rounded-2xl bg-gradient-to-br from-accent-purple to-accent-purple px-8 py-4 text-center text-2xl font-bold no-underline transition duration-300 hover:from-accent-green hover:to-accent-purple",
        customClass,
      ]}
      href={href}
      id={id}
      {...props}
    >
      {hasSlot ? <slot /> : text}
    </a>
  )
}
