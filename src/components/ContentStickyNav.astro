---
export interface ContentStickyNavItem {
  id: string;
  label: string;
}

interface Props {
  items: ContentStickyNavItem[];
}

const { items } = Astro.props;
const spyIds = items.map((i) => i.id);
---

<div
  aria-hidden="true"
  class="pointer-events-none fixed left-0 right-0 top-0 z-40 hidden -translate-y-full opacity-0 transition-all duration-300 ease-out xl:block"
  id="content-sticky-subnav-root"
>
  <div class="mx-auto max-w-screen-2xl px-4 pt-3 sm:px-6 lg:px-8">
    <nav
      aria-label="In-page sections"
      class="grid grid-cols-[1fr_auto_1fr] items-center gap-x-4 gap-y-2 rounded-xl bg-[#00022d] px-4 py-4"
    >
      <div class="flex min-w-0 justify-self-start">
        <a
          aria-label="With the Ranks — home"
          class="inline-flex shrink-0 items-center no-underline"
          href="/"
        >
          <img
            alt=""
            class="h-8 w-auto max-w-[11rem] object-contain object-left sm:h-9"
            height="36"
            src="/assets/home/logo.svg"
            width="176"
          />
        </a>
      </div>
      <div class="flex max-w-full min-w-0 flex-wrap items-center justify-center gap-x-2 gap-y-2 overflow-x-auto [scrollbar-width:thin]">
        {
          items.map((item) => (
            <a
              class="content-sticky-nav-link shrink-0 rounded-md px-2.5 py-2 font-sans text-sm font-normal text-white no-underline transition-colors hover:bg-white/10 hover:!text-white xl:px-3 xl:text-base"
              data-content-spy={item.id}
              href={`#${item.id}`}
            >
              {item.label}
            </a>
          ))
        }
      </div>
      <!-- Balances the logo column so the link group stays visually centered -->
      <div aria-hidden="true" class="min-w-0" />
    </nav>
  </div>
</div>

<script is:inline define:vars={{ spyIds }}>
  const setupContentStickyNav = () => {
    const root = document.getElementById("content-sticky-subnav-root");
    const siteNav = document.getElementById("site-nav");
    if (!root || !siteNav || root.dataset.bound === "true") return;
    root.dataset.bound = "true";

    const show = () => {
      root.classList.remove("opacity-0", "-translate-y-full", "pointer-events-none");
      root.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
      root.removeAttribute("aria-hidden");
    };
    const hide = () => {
      root.classList.add("opacity-0", "-translate-y-full", "pointer-events-none");
      root.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
      root.setAttribute("aria-hidden", "true");
    };

    const io = new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) hide();
        else show();
      },
      { threshold: 0, rootMargin: "0px" },
    );
    io.observe(siteNav);

    const links = root.querySelectorAll("a[data-content-spy]");
    let lastCurrent = "";
    const onScroll = () => {
      const y = 120;
      let current = spyIds[0] ?? "";
      for (const id of spyIds) {
        const el = document.getElementById(id);
        if (!el) continue;
        if (el.getBoundingClientRect().top <= y) current = id;
      }
      if (current === lastCurrent) return;
      lastCurrent = current;
      links.forEach((a) => {
        const target = a.getAttribute("data-content-spy");
        if (!target) return;
        if (target === current) a.classList.add("bg-white/20");
        else a.classList.remove("bg-white/20");
      });
    };
    window.addEventListener("scroll", () => requestAnimationFrame(onScroll), { passive: true });
    onScroll();
  };

  document.addEventListener("DOMContentLoaded", setupContentStickyNav);
  document.addEventListener("astro:page-load", setupContentStickyNav);
</script>
