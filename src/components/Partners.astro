---
const logos = [
  { src: "/assets/350.svg", alt: "350 logo", class: "max-h-16 max-w-[170px]" },
  { src: "/assets/indivisible.svg", alt: "Indivisible logo", class: "max-h-9 max-w-[210px]" },
  { src: "/assets/bernie.svg", alt: "Bernie logo", class: "max-h-16 max-w-[190px]" },
  { src: "/assets/home/partner-more-perfect-union.png", alt: "More Perfect Union logo", class: "max-h-16 max-w-[200px]" },
  { src: "/assets/opin.svg", alt: "Power in Numbers logo", class: "max-h-16 max-w-[180px]" },
  { src: "/assets/untidy_logo.webp", alt: "Untidy Origins logo", class: "max-h-20 max-w-[180px]" },
  { src: "/assets/AELP.svg", alt: "American Economic Liberties Project logo", class: "max-h-20 max-w-[180px]" },
  { src: "/assets/FCM.png", alt: "Fight Corporate Monopolies logo", class: "max-h-20 max-w-[180px]" },
];
const marqueeLogos = [...logos, ...logos];
---

<section class="bg-brand-blue py-8 sm:py-10">
  <div class="mx-auto max-w-screen-2xl px-4 text-center text-white sm:px-6 lg:px-8">
    <p class="mb-8 text-base font-normal leading-none text-white sm:mb-10 sm:text-2xl">
      With the Ranks is trusted by organizers from:
    </p>
  </div>

  <div class="relative left-1/2 w-screen -translate-x-1/2 overflow-hidden py-2">
    <div class="logo-carousel animate-scroll flex w-max items-center gap-8 px-4 sm:px-6 lg:px-8">
      {
        marqueeLogos.map((logo) => (
          <div class="logo-tile flex h-32 w-[248px] shrink-0 items-center justify-center rounded-2xl bg-black/20 px-10 py-8 sm:w-[280px]">
            <img
              alt={logo.alt}
              class:list={[
                "h-auto w-auto object-contain",
                logo.alt === "More Perfect Union logo" && "h-[52px] w-[200px] max-h-none max-w-none opacity-100",
                logo.class,
              ]}
              src={logo.src}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .animate-scroll {
    animation: scroll 42s linear infinite;
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
