---
const logos = [
  { src: "/assets/350.svg", alt: "350 logo", class: "max-h-16 max-w-[170px]" },
  { src: "/assets/indivisible.svg", alt: "Indivisible logo", class: "max-h-9 max-w-[210px]" },
  { src: "/assets/bernie.svg", alt: "Bernie logo", class: "max-h-16 max-w-[190px]" },
  { src: "/assets/home/partner-more-perfect-union.png", alt: "More Perfect Union logo", class: "max-h-16 max-w-[200px]" },
  { src: "/assets/opin.svg", alt: "Power in Numbers logo", class: "max-h-16 max-w-[180px]" },
  { src: "/assets/untidy_logo.webp", alt: "Untidy Origins logo", class: "max-h-20 max-w-[180px]" },
  { src: "/assets/AELP.svg", alt: "American Economic Liberties Project logo", class: "max-h-20 max-w-[180px]" },
  { src: "/assets/FCM.png", alt: "Fight Corporate Monopolies logo", class: "max-h-20 max-w-[180px]" },
];
const marqueeLogos = [...logos, ...logos];
---

<section class="bg-brand-blue py-8 sm:py-10">
  <div class="mx-auto max-w-screen-2xl px-4 text-center text-white sm:px-6 lg:px-8">
    <p class="mb-8 text-base font-normal leading-none text-white sm:mb-10 sm:text-2xl">
      With the Ranks is trusted by organizers from:
    </p>
  </div>

  <div
    id="partners-scroll"
    class="relative left-1/2 w-screen -translate-x-1/2 cursor-grab overflow-x-auto py-2 select-none [scrollbar-width:none] active:cursor-grabbing [&::-webkit-scrollbar]:hidden"
  >
    <div class="flex w-max items-center gap-8 px-4 sm:px-6 lg:px-8">
      {
        marqueeLogos.map((logo) => (
          <div class="logo-tile flex h-32 w-[248px] shrink-0 items-center justify-center rounded-2xl bg-black/20 px-10 py-8 sm:w-[280px]">
            <img
              alt={logo.alt}
              draggable="false"
              class:list={[
                "h-auto w-auto object-contain pointer-events-none",
                logo.alt === "More Perfect Union logo" && "h-[52px] w-[200px] max-h-none max-w-none opacity-100",
                logo.class,
              ]}
              src={logo.src}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const el = document.getElementById("partners-scroll") as HTMLElement | null;
  if (el) {
    const speed = .6;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let paused = prefersReducedMotion;
    let isDragging = false;
    let dragStartX = 0;
    let dragScrollStart = 0;

    // Auto-scroll loop — resets seamlessly at the halfway point (doubled logos)
    function tick() {
      if (!paused && !isDragging && el) {
        el.scrollLeft += speed;
        const half = el.scrollWidth / 2;
        if (el.scrollLeft >= half) {
          el.scrollLeft -= half;
        }
      }
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    // Pause on hover
    el.addEventListener("mouseenter", () => { paused = true; });
    el.addEventListener("mouseleave", () => { if (!isDragging) paused = false; });

    // Mouse drag-to-scroll
    el.addEventListener("mousedown", (e) => {
      isDragging = true;
      paused = true;
      dragStartX = e.pageX;
      dragScrollStart = el.scrollLeft;
    });
    window.addEventListener("mouseup", () => {
      if (isDragging) {
        isDragging = false;
        paused = false;
      }
    });
    el.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      e.preventDefault();
      el.scrollLeft = dragScrollStart - (e.pageX - dragStartX);
    });

    // Touch drag-to-scroll
    let touchStartX = 0;
    let touchScrollStart = 0;
    el.addEventListener("touchstart", (e) => {
      paused = true;
      touchStartX = e.touches[0].pageX;
      touchScrollStart = el.scrollLeft;
    }, { passive: true });
    el.addEventListener("touchmove", (e) => {
      el.scrollLeft = touchScrollStart - (e.touches[0].pageX - touchStartX);
    }, { passive: true });
    el.addEventListener("touchend", () => {
      if (!prefersReducedMotion) paused = false;
    }, { passive: true });
  }
</script>
