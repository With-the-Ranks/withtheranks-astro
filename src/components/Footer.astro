---
const toolsLinks = [{ href: "/spoke", label: "Spoke" }];
const connectLinks = [{ href: "/contact", label: "Say Hello" }];
const workLinks = [{ href: "/our-work", label: "Case Studies" }, { href: "/about", label: "About Our Co-Op" }];
const supportLinks = [{ href: "https://spoke.withtheranks.com/", label: "Spoke Support" }, { href: "/contact", label: "Contact Us" }];

const socialIcons = [
  { class: "iconoir-instagram", label: "Instagram" },
  { class: "iconoir-tiktok", label: "TikTok" },
  { class: "iconoir-twitter", label: "Twitter" },
  { class: "iconoir-x", label: "X" },
  { class: "iconoir-discord", label: "Discord" },
] as const;
---

<footer class="border-black/20 bg-brand-blue-deep text-brand-cream">
  <div class="mx-auto max-w-screen-2xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28">
    <div class="mt-20 mb-16 sm:mt-24 lg:mt-0 lg:mb-20">
      <img alt="With the Ranks Worker Cooperative" class="mx-auto h-auto w-full max-w-full" src="/assets/home/footer-wordmark.svg" />
    </div>

    <div class="mt-10 flex items-center justify-center gap-5 text-brand-cream sm:mt-12 sm:gap-6">
      {socialIcons.map((item) => (
        <span class="inline-flex size-7 items-center justify-center sm:size-8" role="img" aria-label={item.label}>
          <i class:list={[item.class, "not-italic text-[26px] leading-none sm:text-[28px]"]} aria-hidden="true" />
        </span>
      ))}
    </div>

    <p class="mx-auto mt-16 max-w-[618px] text-center text-base text-brand-cream sm:text-[20px]">
      This site and its content are <a href="https://github.com/With-the-Ranks/withtheranks-astro" target="_blank" class="font-bold underline underline-offset-4 text-white">open-source</a> under the <a href="https://github.com/With-the-Ranks/withtheranks-astro/blob/main/LICENSE" target="_blank" class="font-bold underline underline-offset-4 text-white">GNU General Public License</a>, except where third-party assets, client references, or partner content carry their own licenses.
      <br />
      <br />
      We don’t use cookies.
    </p>
  </div>
</footer>
