---
const supportLinks = [{ href: "/docs", label: "Spoke" }, { href: "/contact", label: "Get in touch" }];
const connectLinks = ["Newsletter", "RSS", "Mastodon", "BlueSky"];
const workLinks = [{ href: "/our-work", label: "Case Studies" }, { href: "/about", label: "About Us" }, { href: "/texting", label: "Spoke Texting" }];
---

<footer class="border-black/20 bg-brand-blue-deep text-brand-cream">
  <div class="mx-auto max-w-home-shell px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28">
    <div class="grid justify-items-center gap-12 text-center sm:justify-items-start sm:text-left md:grid-cols-3 md:gap-10 lg:gap-16">
      <section class="space-y-4">
        <h2 class="mb-0 font-display text-5xl font-normal leading-none sm:text-home-footer">Support</h2>
        <div class="space-y-3">
          {supportLinks.map((link) => <a class="block text-xl font-normal text-brand-cream/40 underline underline-offset-5 transition-colors hover:text-brand-cream sm:text-2xl" href={link.href}>{link.label}</a>)}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="mb-0 font-display text-5xl font-normal leading-none sm:text-home-footer">Connect</h2>
        <div class="space-y-3">
          {connectLinks.map((label) => <span aria-disabled="true" class="block cursor-default text-xl font-normal text-brand-cream/40 underline underline-offset-5 sm:text-2xl">{label}</span>)}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="mb-0 font-display text-5xl font-normal leading-none sm:text-home-footer">Our Work</h2>
        <div class="space-y-3">
          {workLinks.map((link) => <a class="block text-xl font-normal text-brand-cream/40 underline underline-offset-5 transition-colors hover:text-brand-cream sm:text-2xl" href={link.href}>{link.label}</a>)}
        </div>
      </section>
    </div>

    <div class="mt-20 sm:mt-24 lg:mt-32">
      <img alt="With the Ranks Worker Cooperative" class="mx-auto h-auto w-full max-w-sm sm:max-w-2xl lg:max-w-footer-wordmark" src="/assets/home/footer-wordmark.svg" />
    </div>
  </div>
</footer>
