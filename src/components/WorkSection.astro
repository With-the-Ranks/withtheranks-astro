---
import Button from "./Button.astro";
import InfoCard from "./InfoCard.astro";

interface WorkCard {
  href: string;
  tag: string;
  title: string;
  image: string;
  overlay: string;
  position: string;
  titleColor: string;
}

interface Props {
  workCards: WorkCard[];
}

const { workCards } = Astro.props as Props;
---

<section class="scroll-mt-24 border-b-8 border-black/20 bg-brand-blue" id="work">
  <div class="mx-auto max-w-screen-2xl px-4 py-16 text-white sm:px-6 lg:px-8 lg:py-32">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="heading-section mb-4 font-display font-normal text-white">
        No client too small.<br />
        No cause too big.
      </h2>
      <p class="body-section mb-6 text-white">
        With the Ranks works with organizations of all sizes, from the smallest city council races to the largest global non-profits.
      </p>
      <p class="body-section mb-0 text-white">
        We love building beautiful websites, developing custom organizing tools, running A/B testing programs, hosting Spoke peer-to-peer texting, and doing whatever we can to help good causes prevail.
      </p>
    </div>

    <div class="mt-12 grid gap-4 lg:mt-16 lg:grid-cols-2">
      {
        workCards.map((card) => (
          <a
            class="text-inherit no-underline"
            href={card.href}
            rel={card.href.startsWith("http") ? "noreferrer" : undefined}
            target={card.href.startsWith("http") ? "_blank" : undefined}
          >
            <InfoCard
              class="flex h-80 flex-col justify-end rounded-sm border-4 border-black p-6 lg:h-[404px] lg:p-8"
              style={`background-image: ${card.overlay}, url('${card.image}'); background-position: ${card.position}; background-size: cover;`}
            >
              <span class="mb-3 inline-flex w-fit rounded-lg bg-brand-blue-tag px-3 py-2 text-base font-bold text-white">
                {card.tag}
              </span>
              <h3 class={`heading-card mb-0 max-w-md font-bold ${card.titleColor}`}>
                {card.title}
              </h3>
            </InfoCard>
          </a>
        ))
      }
    </div>

    <div class="mt-8 flex justify-center lg:mt-10">
      <Button class="label-button px-8 py-6" href="/our-work" variant="cta">
        <span>See more of our work</span>
      </Button>
    </div>
  </div>
</section>
