---
import AboutSection from "../components/AboutSection.astro";
import ContactOptionsSection from "../components/ContactOptionsSection.astro";
import HeroSection from "../components/HeroSection.astro";
import Layout from "../layouts/Layout.astro";
import MailerSection from "../components/MailerSection.astro";
import ToolsSection from "../components/ToolsSection.astro";
import WorkSection from "../components/WorkSection.astro";

const calendlyLink = "https://calendly.com/with-the-ranks/team-meeting";

const tools = [
  { name: "Mailer", version: "v0.5.0", icon: "/assets/home/mailer-icon.svg", href: "https://github.com/With-the-Ranks/mailer", lead: "Mailer is the easiest way to send organizing emails.", bodyHtml: "Built from the ground up by <strong>With the Ranks</strong>, <strong>Mailer</strong> combines an intuitive email editor with smart scheduling features to get anyone up to speed running an effective email program in record time." },
  { name: "Spoke", version: "v2.0.7", icon: "/assets/home/spoke-icon.svg", href: "https://github.com/With-the-Ranks/Spoke", lead: "Spoke is the cheapest peer-to-peer texting platform on the market.", bodyHtml: "Built by members of the Bernie 2016 campaign, and maintained in various forms by MoveOn, State Voices and Politics Rewired, we&rsquo;ve updated Spoke for the modern era of organizing." },
];
const workCards = [
  { href: "/our-work", tag: "Custom Development", title: "Going Neighbor to Neighbor with Indivisible.", image: "/assets/home/work-indivisible.png", overlay: "linear-gradient(180deg, rgba(43,61,86,0) 46%, rgba(43,61,86,0.98) 84%)", position: "center", titleColor: "text-white" },
  { href: "/#mailer", tag: "Open Source Tools", title: "Announcing Mailer, the easiest way to send organizing emails.", image: "/assets/home/work-mailer.png", overlay: "linear-gradient(180deg, rgba(255,255,255,0) 52%, rgba(255,255,255,0.96) 82%)", position: "center", titleColor: "text-black" },
  { href: "/projects/website-2.0", tag: "Open Source Tools", title: "Building an open-source website platform for organizers.", image: "/assets/home/work-website-platform.png", overlay: "linear-gradient(180deg, rgba(255,255,255,0) 40%, rgba(255,255,255,0.96) 76%)", position: "center top", titleColor: "text-black" },
  { href: "https://berniesanders.com", tag: "Websites", title: "Redesigning Bernie Sanders’ website for the Fighting Oligarchy Tour.", image: "/assets/home/work-bernie.jpg", overlay: "linear-gradient(180deg, rgba(0,0,0,0) 48%, rgba(0,0,0,0.95) 100%)", position: "center", titleColor: "text-white" },
];
const contactCards = [
  { href: "/contact", title: "Start a new project", description: "From custom websites to full-fledged web products, let us know what you need.", icon: "/assets/home/contact-project.svg" },
  { href: "/texting", title: "Sign up for Spoke", description: "Power your organizing efforts with affordable peer-to-peer texting at scale.", icon: "/assets/home/contact-spoke.svg" },
  { href: "/contact", title: "Just say hello", description: "Not sure what to choose? Just drop us a message and we’ll get you pointed in the right direction.", icon: "/assets/home/contact-hello.svg" },
  { href: calendlyLink, title: "Schedule a meeting", description: "Prefer to meet virtually? Book a time with a team member and we’ll help point you in the right direction.", icon: "/assets/home/contact-schedule.svg", external: true },
];
---

<Layout title="With the Ranks">
  <main class="overflow-x-hidden">
    <HeroSection />
    <MailerSection />
    <ToolsSection tools={tools} />
    <WorkSection workCards={workCards} />
    <AboutSection />
    <ContactOptionsSection contactCards={contactCards} />
  </main>
</Layout>
