---
import AboutSection from "../components/AboutSection.astro";
import ContactOptionsSection from "../components/ContactOptionsSection.astro";
import HeroSection from "../components/HeroSection.astro";
import Layout from "../layouts/Layout.astro";
import MailerSection from "../components/MailerSection.astro";
import NewsletterSection from "../components/NewsletterSection.astro";
import Partners from "../components/Partners.astro";
import WorkSection from "../components/WorkSection.astro";

const workCards = [
  { href: "https://mpuniversity.us/", tag: "Custom Development", title: "Building a new generation of organizers with More Perfect University.", image: "/assets/home/MPU.png", overlay: "linear-gradient(180deg, rgba(43,61,86,0) 46%, rgba(43,61,86,0.98) 84%)", position: "center", titleColor: "text-white", target: "_blank" },
  { href: "/spoke", tag: "Open Source Tools", title: "Redesigning the Spoke experience for organizers of every level.", image: "/assets/home/work-spoke-redesign.png", overlay: "linear-gradient(180deg, rgba(255,255,255,0) 52%, rgba(255,255,255,0.96) 82%)", position: "center", titleColor: "text-black" },
  { href: "https://thegeorgiavoterguide.com/", tag: "Open Source Tools", title: "Delivering personalized voting information for monumental elections in Georgia.", image: "/assets/home/georgia-voter-guide.png", overlay: "linear-gradient(180deg, rgba(255,255,255,0) 42%, rgba(255,255,255,0.96) 71%)", position: "center", titleColor: "text-black", target: "_blank" },
  { href: "https://berniesanders.com", tag: "Websites & P2P Texting", title: "Powering Bernie Sanders’ Fighting Oligarchy Tour.", image: "/assets/home/work-bernie.jpg", overlay: "linear-gradient(180deg, rgba(0,0,0,0) 48%, rgba(0,0,0,0.95) 100%)", position: "center", titleColor: "text-white" },
];
---

<Layout title="With the Ranks">
  <main class="overflow-x-hidden">
    <HeroSection />
    <MailerSection />
    <Partners />
    <WorkSection workCards={workCards} />
    <AboutSection />
    <ContactOptionsSection/>
    <NewsletterSection />
  </main>
</Layout>
