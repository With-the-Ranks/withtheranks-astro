---
import Layout from "../layouts/Layout.astro";
import StickySubNav from "../components/spoke/StickySubNav.astro";
import SpokeBackedSection from "../components/spoke/SpokeBackedSection.astro";
import SpokeBuiltSection from "../components/spoke/SpokeBuiltSection.astro";
import SpokeFaqSection from "../components/spoke/SpokeFaqSection.astro";
import SpokeHero from "../components/spoke/SpokeHero.astro";
import SpokeOpenSourceSection from "../components/spoke/SpokeOpenSourceSection.astro";
import SpokePricingSection from "../components/spoke/SpokePricingSection.astro";
import SpokeSignupSection from "../components/spoke/SpokeSignupSection.astro";
import SpokeStepsSection from "../components/spoke/SpokeStepsSection.astro";
import type { StickySubNavItem } from "../components/spoke/StickySubNav.astro";
import { CALENDLY_TEAM_MEETING } from "../constants/spoke";

const stickyNavItems: StickySubNavItem[] = [
  { label: "About", href: "#overview", spyId: "overview" },
  { label: "Features", href: "#features", spyId: "features" },
  { label: "Pricing", href: "#pricing", spyId: "pricing" },
  { label: "Support", href: "#backed", spyId: "backed" },
  { label: "Open Source", href: "#open-source", spyId: "open-source" },
  { label: "FAQ", href: "#faq", spyId: "faq" },
];
---

<Layout navSurfaceClass="bg-[#212bdd]" theme="dark" title="Spoke Texting - With the Ranks">
  <StickySubNav
    items={stickyNavItems}
    scheduleDemoHref={CALENDLY_TEAM_MEETING}
    signUpHref="#signup"
    slot="sticky-subnav"
  />
  <main class="spoke-page">
    <SpokeHero />
    <SpokeStepsSection />
    <SpokeBuiltSection />
    <SpokePricingSection />
    <SpokeBackedSection />
    <SpokeOpenSourceSection />
    <SpokeFaqSection />
    <SpokeSignupSection />
  </main>
</Layout>
