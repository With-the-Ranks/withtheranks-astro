---
export interface Props {
  title: string;
  bannerCategory?: string;
  bannerTitle?: string;
  bannerSubtitle?: string;
  theme?: string;
  bannerColor?: string;
  toc?: { id: string; label: string }[];
}
const { title, bannerCategory, bannerTitle, bannerSubtitle, theme, bannerColor, toc } = Astro.props;
import Layout from "../layouts/Layout.astro";
---
<Layout title={title} theme={theme}>
  <div class="px-2 sm:px-0">
    <!-- Banner Section -->
    <section class={`container mx-auto rounded-2xl sm:rounded-3xl lg:rounded-[32px] p-6 sm:p-8 lg:p-12 xl:p-16 relative overflow-hidden ${bannerColor ? bannerColor : 'bg-[#ffe872]'}`}>
      {bannerCategory && (
        <div class="inline-block max-w-4xl rounded-full border border-[#252753]/25 bg-[#252753]/12 px-3 py-1 text-xs font-bold text-[#0b124c] sm:px-4 sm:py-1.5 sm:text-sm">
          {bannerCategory}
        </div>
      )}
      {bannerTitle && (
        <h2 class="text-[#252753] text-2xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.1] mb-6" set:html={bannerTitle}></h2>
      )}
      {bannerSubtitle && (
        <p class="text-[#252753] text-lg sm:text-3xl mb-8 max-w-4xl">
          {bannerSubtitle}
        </p>
      )}
    </section>

    <!-- Main Content Section -->
    <main class="mx-auto pb-8 sm:pb-12 lg:pb-16">
      <div class="container mx-auto relative z-2 px-4">
        {toc?.length ? (
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-5 lg:gap-20 mt-5 lg:mt-16 items-start">
            <!-- Table of Contents -->
            <aside class="w-full mx-auto rounded-2xl bg-[#959AF6]/20 p-6 text-[#252753] sm:rounded-3xl lg:sticky lg:top-10 lg:col-span-1 lg:rounded-[32px] on-this-page">
              <p class="mb-2 font-sans text-base leading-tight font-semibold text-[#252753] sm:text-lg">On this page</p>
              {toc.map(({ id, label }) => (
                <hr class="border-[#959AF6] border-t-2 opacity-20 my-3">
                <a class="block rounded-md px-1 py-0.5 text-[#252753] no-underline hover:bg-[#959AF6]/40" href={`#${id}`} >
                  <span class="block font-sans text-sm leading-snug font-medium text-[#252753] sm:text-base">{label}</span>
                </a>
              ))}
            </aside>
            <!-- Content -->
            <article class="relative lg:col-span-3 text-[#252753]">
              <slot />
            </article>
          </div>
        ) : (
          <article class="w-full lg:w-2/3 mx-auto mt-16 text-[#252753]">
            <slot />
          </article>
        )}
      </div>
    </main>
  </div>
</Layout>